# Firebase Console > Project settings > Your apps > Web app config
# 실제 배포 시 .env.local 파일을 만들고 아래 값을 채우세요.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase App Check - optional but recommended before public operation
# Firebase Console > App Check > Web app > reCAPTCHA Enterprise
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Google AdSense - optional
# Example client id format: ca-pub-1234567890123456
VITE_ADSENSE_ENABLED=false
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_SIDEBAR_SLOT=
VITE_ADSENSE_FOOTER_SLOT=

# Site metadata
VITE_SITE_URL=https://example.com
VITE_CONTACT_EMAIL=contact@example.com
VITE_OPERATOR_NAME=Your Studio Name
